# ============================================================
# Trading Bot — Variables d'environnement
# ============================================================
# INSTRUCTIONS:
# 1. Copiez ce fichier: cp .env.example .env
# 2. Remplissez vos vraies valeurs dans .env
# 3. NE METTEZ JAMAIS .env en git (il est dans .gitignore)
# 4. Ce fichier (.env.example) peut rester public
# ============================================================

# ---- BROKER: Alpaca (OBLIGATOIRE pour le trading) ----
# Obtenir les clés: https://app.alpaca.markets/auth/login
# Pour PAPER trading (test):
BROKER_API_KEY=PKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
BROKER_API_SECRET=yyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyy
BROKER_BASE_URL=https://paper-api.alpaca.markets/v2

# Pour LIVE trading (réel):
# Remplacez les clés ET changez l'URL à:
# BROKER_BASE_URL=https://api.alpaca.markets/v2

# ---- IA: Anthropic Claude (RECOMMANDÉ) ----
# Obtenir la clé: https://console.anthropic.com/
# Utilisé pour l'analyse stratégique et les recommandations
# Optionnel: si laissé vide, la couche IA est désactivée
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---- ALERTES: Telegram (OPTIONNEL) ----
# Configuration: https://core.telegram.org/bots/tutorial
# Crée un bot avec @BotFather, puis ajoute-le à un groupe
TELEGRAM_BOT_TOKEN=123456789:ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefgh
TELEGRAM_CHAT_ID=987654321

# ---- ALERTES: Discord (OPTIONNEL) ----
# Crée un Webhook dans les paramètres du serveur Discord
# Alternative à Telegram
DISCORD_WEBHOOK_URL=https://discordapp.com/api/webhooks/xxxxxxxxxxxxx/yyyyyyyyyyyyyyyyyyyyy

# ---- LOGGING (OPTIONNEL) ----
# Niveau de log: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ---- DATA (OPTIONNEL) ----
# Durée du cache (en secondes) : 300 = 5 min
CACHE_TTL_SECONDS=300

# ---- Alerts: Email ----
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password
EMAIL_RECIPIENT=alerts@yourdomain.com

# ---- Paths ----
LOG_DIR=data/logs
